{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://skazka-vostoka.vtheory.ru/api/v1/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://skazka-vostoka.vtheory.ru/storage/:path*"
    },
    {
      "source": "/((?!api/|storage/).*)",
      "destination": "/"
    }
  ]
}
