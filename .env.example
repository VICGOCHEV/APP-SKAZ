# Скопируй этот файл в .env.local и настрой под свою разработку.
# .env.local не коммитится (см. .gitignore).

# --- Режим данных ---
# true (или не указано) — фронт на моках из src/mocks/
# false — фронт ходит в реальный API (см. ниже настройки baseURL)
VITE_USE_MOCKS=true

# --- Адрес API ---
# Базовый URL для axios-инстанса. По умолчанию /api/v1 (same-origin).
# Если указать VITE_API_PROXY_TARGET ниже — Vite dev-сервер будет проксировать
# /api/v1/* на этот адрес (обходит CORS).
VITE_API_URL=/api/v1

# Хост для прокси в dev-режиме. Примеры:
#   https://skazka-vostoka.ru
#   http://localhost:8000
# Не заканчивайте слешем.
# VITE_API_PROXY_TARGET=https://skazka-vostoka.ru

# --- Медиа ---
# Префикс для относительных путей в attachments[].path.
# Если бэкенд возвращает полные URL — оставляй пустым.
# VITE_API_MEDIA_URL=https://cdn.skazka-vostoka.ru
